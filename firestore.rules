
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --------------------------------------------------------------------------------
    // Helper Functions
    // --------------------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      // Admin authority via custom claim (preferred) or trusted admin email fallback
      return isSignedIn() && (
        request.auth.token.admin == true
        || request.auth.token.email == 'abdulwassaynisar@gmail.com'
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    function isStudent(userId) {
      return exists(/databases/$(database)/documents/students/$(userId));
    }

    function isCompany(userId) {
      return exists(/databases/$(database)/documents/companies/$(userId));
    }

    function isAssignedVolunteerForAssignment() {
      return isSignedIn() && resource.data.volunteerId == request.auth.uid;
    }

    function changedRoomAssignmentStatusFieldsOnly() {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly([
        'checkInStatus',
        'checkInTime',
        'checkInMarkedByVolunteerId',
        'companyLeftStatus',
        'companyLeftTime',
        'companyLeftMarkedByVolunteerId'
      ]);
    }

    function isValidVolunteerCheckInUpdate() {
      return request.resource.data.checkInStatus == true
        && resource.data.checkInStatus != true
        && request.resource.data.checkInMarkedByVolunteerId == request.auth.uid
        && request.resource.data.companyLeftStatus == resource.data.companyLeftStatus
        && request.resource.data.companyLeftTime == resource.data.companyLeftTime
        && request.resource.data.companyLeftMarkedByVolunteerId == resource.data.companyLeftMarkedByVolunteerId;
    }

    function isValidVolunteerCompanyLeftUpdate() {
      return request.resource.data.companyLeftStatus == true
        && resource.data.companyLeftStatus != true
        && request.resource.data.companyLeftMarkedByVolunteerId == request.auth.uid
        && request.resource.data.checkInStatus == resource.data.checkInStatus
        && request.resource.data.checkInTime == resource.data.checkInTime
        && request.resource.data.checkInMarkedByVolunteerId == resource.data.checkInMarkedByVolunteerId;
    }

    // --------------------------------------------------------------------------------
    // Global Admin Override (CRITICAL: MUST BE AT TOP)
    // --------------------------------------------------------------------------------
    
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // --------------------------------------------------------------------------------
    // Collection Group Rules (REQUIRED for Global Attendance Tracking)
    // --------------------------------------------------------------------------------
    
    match /{path=**}/volunteerShifts/{shiftId} {
      allow read: if isSignedIn();
    }

    match /{path=**}/projectSpotAssignments/{assignmentId} {
      allow read: if isSignedIn();
      // Write/Update handled by isAdmin() override above or specific owner rules
    }

    // --------------------------------------------------------------------------------
    // Role-Specific Collection Rules
    // --------------------------------------------------------------------------------

    match /eventState/status {
      allow read: if isSignedIn();
    }

    match /userProfiles/{userProfileId} {
      allow get: if isSignedIn();
      allow create: if isOwner(userProfileId) && !('admin' in request.resource.data.roles);
      allow update: if isExistingOwner(userProfileId) && !('admin' in request.resource.data.roles);
    }

    match /students/{studentId} {
      allow read: if isSignedIn();
      allow create: if isOwner(studentId);
      allow update: if isExistingOwner(studentId);
    }

    match /companies/{companyId} {
      allow get: if isSignedIn(); 
      allow list: if isSignedIn();
      allow create: if isOwner(companyId);
      allow update: if isExistingOwner(companyId);
    }

    match /companies/{companyId}/shortlistedStudents/{studentId} {
        allow read, write: if isOwner(companyId);
    }

    match /volunteers/{volunteerId} {
      allow get: if isOwner(volunteerId);
      allow create: if isOwner(volunteerId);
      allow update: if isExistingOwner(volunteerId);
    }

    match /projects/{projectId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isStudent(request.auth.uid);
      allow update: if isSignedIn() && (request.auth.uid in resource.data.teamMemberIds);
    }

    match /jobFairs/{jobFairId} {
      allow get, list: if isSignedIn();
    }

    match /jobFairs/{jobFairId}/roomAssignments/{roomAssignmentId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow update: if isAssignedVolunteerForAssignment()
        && changedRoomAssignmentStatusFieldsOnly()
        && (isValidVolunteerCheckInUpdate() || isValidVolunteerCompanyLeftUpdate());
    }

    match /jobFairs/{jobFairId}/projectSpotAssignments/{assignmentId} {
      allow read: if isSignedIn();
      // Allow student to confirm presence at their own spot
      allow update: if isOwner(assignmentId);
    }

    match /interviews/{interviewId} {
      allow read: if isSignedIn() && (request.auth.uid == resource.data.studentId || request.auth.uid == resource.data.companyId);
      allow create: if isSignedIn()
        && isCompany(request.auth.uid)
        && request.resource.data.companyId == request.auth.uid
        && exists(/databases/$(database)/documents/students/$(request.resource.data.studentId))
        && request.resource.data.status == 'Scheduled';
      allow update: if isSignedIn() && (request.auth.uid == resource.data.companyId || request.auth.uid == resource.data.studentId);
    }

    match /portalReviews/{reviewId} {
      allow create, update: if isSignedIn() && isCompany(request.auth.uid) && request.auth.uid == reviewId;
      allow read: if isSignedIn() && (request.auth.uid == reviewId || isAdmin());
      allow list: if isAdmin();
    }

    match /userProfiles/{userProfileId}/notifications/{notificationId} {
      allow read, update, delete: if isOwner(userProfileId);
      allow create: if isSignedIn() && (
        request.resource.data.recipientUserProfileId == userProfileId
        && (
          isOwner(userProfileId)
          || isCompany(request.auth.uid)
        )
      );
    }
  }
}
